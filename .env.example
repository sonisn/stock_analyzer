# =============================================================================
# stock-analyzer environment variables
# =============================================================================
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — secrets stay local.

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# Claude API key — required if you use any "claude" provider role.
# Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Gemini API key — required if you use any "gemini" provider role.
# Console: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Model selection
# -----------------------------------------------------------------------------
# Default provider + model used by every agent (sentiment, ticker, rerank,
# insider). Change these two vars to swap models everywhere. No code change.
#
#   Examples:
#     LLM_PROVIDER=claude   LLM_MODEL=claude-haiku-4-5     (cheap, fast)
#     LLM_PROVIDER=claude   LLM_MODEL=claude-sonnet-4-6    (smarter, pricier)
#     LLM_PROVIDER=gemini   LLM_MODEL=gemini-3-pro
LLM_PROVIDER=claude
LLM_MODEL=claude-haiku-4-5

# Optional per-role overrides — leave blank to use LLM_PROVIDER/LLM_MODEL.
# Useful for mixing: e.g. cheap Haiku for ticker blocks, smarter Sonnet for
# the macro sentiment synthesis.
SENTIMENT_PROVIDER=
SENTIMENT_MODEL=
TICKER_PROVIDER=
TICKER_MODEL=
RERANK_PROVIDER=
RERANK_MODEL=
INSIDER_PROVIDER=
INSIDER_MODEL=

# -----------------------------------------------------------------------------
# Data sources
# -----------------------------------------------------------------------------
# Tavily search API — powers macro-sentiment news and insider/political
# trade coverage. Free tier ~1000 searches/month.
# Sign up: https://tavily.com
TAVILY_API_KEY=

# chart-img.com — renders TradingView-style chart PNGs (used to embed
# per-holding charts in the portfolio digest email).
# Dashboard: https://chart-img.com/
CHART_IMG_API_KEY=

# SnapTrade — aggregates holdings across your connected brokerages.
# Dashboard: https://snaptrade.com/dashboard
# CLIENT_ID + CONSUMER_KEY come from the SnapTrade dashboard.
# USER_ID + USER_SECRET are returned the first time you register a user
# via the SDK (one-time per user). Persist them and reuse on every run.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=

# -----------------------------------------------------------------------------
# Email delivery (SMTP)
# -----------------------------------------------------------------------------
# Host of your SMTP provider, e.g. smtp.gmail.com or smtp.fastmail.com
SMTP_HOST=

# 465 for SSL (recommended), 587 for STARTTLS.
SMTP_PORT=465

# "true" → SSL on 465; "false" → STARTTLS on 587.
SMTP_USE_SSL=true

# Full SMTP login (usually your email address).
SMTP_USERNAME=

# App-specific password if 2FA is on (required by Gmail / Outlook / iCloud).
SMTP_PASSWORD=

# Display "From" address. Leave blank to default to SMTP_USERNAME.
SMTP_FROM=

# Recipient for analysis emails (you).
EMAIL_TO=

# -----------------------------------------------------------------------------
# Behavior (optional — defaults shown)
# -----------------------------------------------------------------------------
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Directory where rotating log files are written. Default lives under your
# home dir; override if you want to centralize logs elsewhere (e.g. a
# host-mounted volume in containerized runs).
LOG_DIR=~/.stock_analyzer/logs

# Specific log file path. When set, overrides LOG_DIR's auto-naming and
# writes every run to this single file. Leave blank to get one timestamped
# file per run under LOG_DIR.
LOG_FILE=

# Directory where rebalance/discover PDFs are persisted locally before
# the SMTP attempt. A delivery failure never costs you the report — the
# PDF is always saved here.
REPORTS_DIR=~/.stock_analyzer/reports

# Days to look back when fetching insider + political trade coverage.
INSIDER_LOOKBACK_DAYS=5

# -----------------------------------------------------------------------------
# Discover pipeline (cli/discover.py) — find new stocks worth buying
# -----------------------------------------------------------------------------
# Run via: python -m stock_analyzer.cli.discover
#
# Models per stage. Opus runs only 3 high-leverage calls (ranking, red-team,
# sizing); Sonnet runs per-candidate analysis. Override if needed.
DISCOVER_OPUS_MODEL=claude-opus-4-7
DISCOVER_SONNET_MODEL=claude-sonnet-4-6

# Optional watchlist of tickers to always include in the universe (CSV).
DISCOVER_WATCHLIST=

# Cash budget for position sizing in dollars. If unset, sizer outputs
# percentages of available capital instead of dollar amounts.
DISCOVER_CASH_BUDGET=

# Where to persist run history (SQLite). The discover.db file holds BOTH our
# domain tables (runs/picks/candidates) AND Agno Workflow's session log —
# single file, two table sets. Reports are delivered via email (EMAIL_TO /
# SMTP_*) — no file written to disk.
DISCOVER_DB_PATH=~/.stock_analyzer/discover.db

# Ranker consensus voting: run the Opus ranker N times and keep tickers
# that appear in the majority of runs. With temperature=0 across all
# stages, runs should agree near-perfectly; this catches residual variance
# from data freshness (Tavily index, intraday prices). Cost: N x ranker
# calls. Set to 1 to disable.
DISCOVER_CONSENSUS_RUNS=3

# Rebalance aggressiveness — controls how willing the rebalancer is to
# recommend SELL/TRIM/ADD actions that incur tax friction.
#
#   conservative — strict tax-after-EV bar (10%). Forward deterioration
#                  required for any SELL/TRIM. Default until 2026-05.
#   balanced     — risk-reduction trims allowed on overbought (weekly RSI
#                  > 80) + above-target positions, even with short-term
#                  tax cost. 5% post-tax bar. (Recommended default.)
#   aggressive   — tax-aware but not tax-blocked. Recommend churn where
#                  forward signal is meaningfully better. 0% post-tax bar.
#
# The report ALWAYS includes a "Tax-agnostic alternative" section in any
# NO ACTION output, so you see opportunity cost regardless of mode.
DISCOVER_REBALANCE_AGGRESSIVENESS=balanced

# -----------------------------------------------------------------------------
# Macro data (used by discover ranker prompt for regime awareness)
# -----------------------------------------------------------------------------
# FRED API key (St. Louis Fed) — free, instant signup.
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Finnhub API key — free tier covers earnings surprises, analyst
# recommendation trend, price targets, and Form 4 insider transactions.
# Free tier: 60 calls/min, US equities only.
# Register: https://finnhub.io/register
FINNHUB_API_KEY=

# Reuse cached report when present. Caching is disabled in cli/* by
# default — flip the cache code on first if you want this honored.
USE_CACHED_ANALYSIS=1

# -----------------------------------------------------------------------------
# Covered-call writing (optional) — used by cli/rebalance.py
# -----------------------------------------------------------------------------
# Master switch. Set to 0 to disable all CC logic (eligibility, chain
# fetch, rebalancer prompt section). Pipeline runs as before.
CC_ENABLED=1

# Strike selection band (Δ). The Opus rebalancer picks strikes within
# [min, max], leaning toward MIN on high-confidence HOLDs and toward
# MAX on TRIM/low-confidence positions. Defaults are "aggressive
# premium" style — Δ 0.35-0.45 ≈ real chance of assignment.
CC_TARGET_DELTA_MIN=0.35
CC_TARGET_DELTA_MAX=0.45

# Days-to-expiry band. 30-45 DTE = 1 cycle/month, decent theta decay,
# below the long-dated tax-treatment cliff.
CC_DTE_MIN=30
CC_DTE_MAX=45

# Tickers to never write calls against (comma-separated). Useful for
# positions you'd never want to risk losing to assignment.
CC_DENYLIST=

# If expected total premium across all WRITE_CALLs is less than this
# (USD), the rebalancer leaves the premium as cash rather than
# proposing reinvestment trades (avoids friction for tiny premiums).
CC_MIN_PREMIUM_USD=500

# Fraction of expected premium held back when sizing reinvestment
# trades, to account for fill slippage vs. mid-quote estimates.
CC_SLIPPAGE_BUFFER=0.10

# Stub consolidation: sell sub-100 "stub" shares to fund round-lot
# completion elsewhere (expanding future CC capacity). Set 0 to
# disable.
CC_STUB_OPTIMIZATION=1

# Don't propose stub consolidation when the stub is worth less than
# this (USD) — trade friction wastes the gain.
CC_MIN_STUB_USD=1000

# -----------------------------------------------------------------------------
# Tradier options data (primary chain provider for covered-call writing)
# -----------------------------------------------------------------------------
# Tradier brokerage API token — gives real-time options chain data WITH
# Greeks (delta, gamma, theta, vega, IV). The CC pipeline uses this as
# the primary chain source; yfinance is the fallback when the key is
# unset or Tradier is unreachable.
#
# Free path to real-time data: open a Tradier brokerage account (no
# funding minimum) at https://tradier.com/signup, then generate an
# access token at https://dash.tradier.com/.
TRADIER_API_KEY=

# Production URL: https://api.tradier.com/v1   (real-time, requires
#                                              brokerage account token)
# Sandbox URL:    https://sandbox.tradier.com/v1   (15-min delayed)
TRADIER_BASE_URL=https://api.tradier.com/v1

# -----------------------------------------------------------------------------
# ORATS IV rank / percentile (covered-call timing signal)
# -----------------------------------------------------------------------------
# ORATS provides IV rank (IVR) and IV percentile per ticker — the
# standard "is this a good time to write covered calls?" signal.
# IVR > 50 = elevated premiums (favorable); IVR < 30 = depressed
# premiums (consider passing on the write).
#
# Free tier: 5 requests / minute. Our rebalance does ONE batched call
# per run (all eligible tickers in one comma-delimited request), well
# within the limit.
#
# Sign up: https://orats.io/data-api (Free tier available.)
ORATS_API_KEY=

# Production endpoint. No sandbox/dev variant needed for free tier.
ORATS_BASE_URL=https://api.orats.io/datav2
