# =============================================================================
# stock-analyzer environment variables
# =============================================================================
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — secrets stay local.

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# Claude API key — required if you use any "claude" provider role.
# Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Gemini API key — required if you use any "gemini" provider role.
# Console: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Model selection
# -----------------------------------------------------------------------------
# Default provider + model used by every agent (sentiment, ticker, rerank,
# insider). Change these two vars to swap models everywhere. No code change.
#
#   Examples:
#     LLM_PROVIDER=claude   LLM_MODEL=claude-haiku-4-5     (cheap, fast)
#     LLM_PROVIDER=claude   LLM_MODEL=claude-sonnet-4-6    (smarter, pricier)
#     LLM_PROVIDER=gemini   LLM_MODEL=gemini-3-pro
LLM_PROVIDER=claude
LLM_MODEL=claude-haiku-4-5

# Optional per-role overrides — leave blank to use LLM_PROVIDER/LLM_MODEL.
# Useful for mixing: e.g. cheap Haiku for ticker blocks, smarter Sonnet for
# the macro sentiment synthesis.
SENTIMENT_PROVIDER=
SENTIMENT_MODEL=
TICKER_PROVIDER=
TICKER_MODEL=
RERANK_PROVIDER=
RERANK_MODEL=
INSIDER_PROVIDER=
INSIDER_MODEL=

# -----------------------------------------------------------------------------
# Data sources
# -----------------------------------------------------------------------------
# Tavily search API — powers macro-sentiment news and insider/political
# trade coverage. Free tier ~1000 searches/month.
# Sign up: https://tavily.com
TAVILY_API_KEY=

# chart-img.com — renders TradingView-style chart PNGs (used to embed
# per-holding charts in the portfolio digest email).
# Dashboard: https://chart-img.com/
CHART_IMG_API_KEY=

# SnapTrade — aggregates holdings across your connected brokerages.
# Dashboard: https://snaptrade.com/dashboard
# CLIENT_ID + CONSUMER_KEY come from the SnapTrade dashboard.
# USER_ID + USER_SECRET are returned the first time you register a user
# via the SDK (one-time per user). Persist them and reuse on every run.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=

# -----------------------------------------------------------------------------
# Email delivery (SMTP)
# -----------------------------------------------------------------------------
# Host of your SMTP provider, e.g. smtp.gmail.com or smtp.fastmail.com
SMTP_HOST=

# 465 for SSL (recommended), 587 for STARTTLS.
SMTP_PORT=465

# "true" → SSL on 465; "false" → STARTTLS on 587.
SMTP_USE_SSL=true

# Full SMTP login (usually your email address).
SMTP_USERNAME=

# App-specific password if 2FA is on (required by Gmail / Outlook / iCloud).
SMTP_PASSWORD=

# Display "From" address. Leave blank to default to SMTP_USERNAME.
SMTP_FROM=

# Recipient for analysis emails (you).
EMAIL_TO=

# -----------------------------------------------------------------------------
# Behavior (optional — defaults shown)
# -----------------------------------------------------------------------------
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Days to look back when fetching insider + political trade coverage.
INSIDER_LOOKBACK_DAYS=5

# -----------------------------------------------------------------------------
# Discover pipeline (cli/discover.py) — find new stocks worth buying
# -----------------------------------------------------------------------------
# Run via: python -m stock_analyzer.cli.discover
#
# Models per stage. Opus runs only 3 high-leverage calls (ranking, red-team,
# sizing); Sonnet runs per-candidate analysis. Override if needed.
DISCOVER_OPUS_MODEL=claude-opus-4-7
DISCOVER_SONNET_MODEL=claude-sonnet-4-6

# Optional watchlist of tickers to always include in the universe (CSV).
DISCOVER_WATCHLIST=

# Cash budget for position sizing in dollars. If unset, sizer outputs
# percentages of available capital instead of dollar amounts.
DISCOVER_CASH_BUDGET=

# Where to persist run history (SQLite). The discover.db file holds BOTH our
# domain tables (runs/picks/candidates) AND Agno Workflow's session log —
# single file, two table sets. Reports are delivered via email (EMAIL_TO /
# SMTP_*) — no file written to disk.
DISCOVER_DB_PATH=~/.stock_analyzer/discover.db

# -----------------------------------------------------------------------------
# Macro data (used by discover ranker prompt for regime awareness)
# -----------------------------------------------------------------------------
# FRED API key (St. Louis Fed) — free, instant signup.
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Reuse cached report when present. Caching is disabled in cli/* by
# default — flip the cache code on first if you want this honored.
USE_CACHED_ANALYSIS=1
